{
  "name": "educonnect",
  "version": "0.1.0",
  "private": true,
  "description": "School communication platform — attendance, homework, notices",
  "scripts": {
    "dev": "turbo dev",
    "build": "pnpm build:web && pnpm build:api",
    "lint": "pnpm --dir apps/web lint",
    "type-check": "pnpm --dir apps/web type-check",
    "test": "pnpm test:web && pnpm test:api",
    "test:web": "pnpm lint && pnpm type-check && NEXT_PUBLIC_APP_URL=http://localhost:3000 NEXT_PUBLIC_API_URL=http://localhost:5000 pnpm --dir apps/web build",
    "test:e2e:web": "pnpm --dir apps/web run test:e2e",
    "test:api": "bash ./scripts/test-backend-local.sh",
    "db:use:local": "bash ./scripts/use-env-profile.sh local",
    "db:use:docker": "bash ./scripts/use-env-profile.sh docker",
    "db:docker:up": "bash ./scripts/db.sh --db docker up",
    "db:docker:down": "bash ./scripts/db.sh --db docker down",
    "db:up": "bash ./scripts/db.sh up",
    "db:down": "bash ./scripts/db.sh down",
    "db:reset": "bash ./scripts/db.sh reset",
    "db:status": "bash ./scripts/db.sh status",
    "db:psql": "bash ./scripts/db.sh psql",
    "db:url": "bash ./scripts/db.sh url",
    "db:update": "bash ./scripts/update-database-local.sh",
    "db:migration:add": "bash ./scripts/add-migration-local.sh",
    "local:backend:run": "bash ./scripts/run-backend-local.sh",
    "local:frontend:run": "bash ./scripts/run-frontend-local.sh",
    "local:backend:test": "bash ./scripts/test-backend-local.sh",
    "local:frontend:test": "bash ./scripts/test-frontend-local.sh",
    "local:backend:run:win": "powershell -ExecutionPolicy Bypass -File ./scripts/run-backend-local.ps1",
    "local:frontend:run:win": "powershell -ExecutionPolicy Bypass -File ./scripts/run-frontend-local.ps1",
    "local:backend:test:win": "powershell -ExecutionPolicy Bypass -File ./scripts/test-backend-local.ps1",
    "local:frontend:test:win": "powershell -ExecutionPolicy Bypass -File ./scripts/test-frontend-local.ps1",
    "db:up:win": "powershell -ExecutionPolicy Bypass -File ./scripts/db.ps1 -Command up",
    "db:down:win": "powershell -ExecutionPolicy Bypass -File ./scripts/db.ps1 -Command down",
    "db:reset:win": "powershell -ExecutionPolicy Bypass -File ./scripts/db.ps1 -Command reset",
    "db:status:win": "powershell -ExecutionPolicy Bypass -File ./scripts/db.ps1 -Command status",
    "db:psql:win": "powershell -ExecutionPolicy Bypass -File ./scripts/db.ps1 -Command psql",
    "db:update:win": "powershell -ExecutionPolicy Bypass -File ./scripts/update-database-local.ps1",
    "db:migration:add:win": "powershell -ExecutionPolicy Bypass -File ./scripts/add-migration-local.ps1",
    "clean": "turbo clean",
    "dev:web": "turbo dev --filter=@educonnect/web",
    "dev:api": "bash ./scripts/run-backend-local.sh",
    "build:web": "NEXT_PUBLIC_APP_URL=http://localhost:3000 NEXT_PUBLIC_API_URL=http://localhost:5000 turbo build --filter=@educonnect/web",
    "build:api": "dotnet publish apps/api/src/EduConnect.Api/EduConnect.Api.csproj -c Release",
    "openapi:generate": "pnpm --dir packages/api-client run generate"
  },
  "devDependencies": {
    "turbo": "^2.4.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
