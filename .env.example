# .env.example — EduConnect
# Copy to .env, then replace the placeholder values you actually need.
# The local helper scripts also provide dev-safe defaults for a few values,
# but keeping them explicit here documents the app's current startup contract.
# Never commit .env — only .env.example.

# ── APP ──────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5000

# ── FEATURE FLAGS (web) ─────────────────────
# Zeigarnik retention strip on dashboard (off by default).
NEXT_PUBLIC_FEATURE_RETENTION_CARD=false
# Optional GA4-style hook: set true and add a measurement ID to enable trackEvent.
NEXT_PUBLIC_FEATURE_ANALYTICS=false
NEXT_PUBLIC_ANALYTICS_MEASUREMENT_ID=

# ── .NET API ─────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
API_PORT=5000

# ── DATABASE ─────────────────────────────────
EDUCONNECT_DB_MODE=docker
POSTGRES_HOST_PORT=5433
DATABASE_URL=postgresql://educonnect:educonnect_dev@localhost:5433/educonnect

# ── JWT ──────────────────────────────────────
JWT_SECRET=replace-with-a-random-64-plus-character-secret
JWT_ISSUER=educonnect-api
JWT_AUDIENCE=educonnect-client

# ── PIN (Parent Auth) ────────────────────────
PIN_MIN_LENGTH=4
PIN_MAX_LENGTH=6

# ── RATE LIMITING ────────────────────────────
RATE_LIMIT_API_PER_USER_PER_MINUTE=60

# ── OBSERVABILITY ────────────────────────────
SENTRY_DSN=                              # optional — leave empty to disable Sentry
SENTRY_ORG=                              # Sentry organization slug (for source maps)
SENTRY_PROJECT=                          # Sentry project slug
NEXT_PUBLIC_SENTRY_DSN=                  # same DSN, exposed to browser for client-side error capture

# ── CORS ─────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── EMAIL (Resend) ───────────────────────────
# Used by /api/auth/forgot-password, /reset-password, /forgot-pin, /reset-pin.
# Local dev can boot with the placeholder values below; replace them with real
# Resend settings before testing email delivery.
RESEND_API_KEY=dev-resend-api-key
RESEND_FROM_EMAIL="EduConnect <no-reply@example.com>"

# ── FILE STORAGE (optional; required for attachment uploads) ─────────
# Leave S3_SERVICE_URL empty to use AWS S3 + AWS_REGION/AWS credentials.
# Set S3_SERVICE_URL plus access keys to use an S3-compatible provider such as R2 or MinIO.
S3_SERVICE_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
AWS_REGION=ap-south-1
